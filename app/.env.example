# Intermarq RAG Backend — Environment Variables
# Copy to .env and fill in your values

# ── LLM Providers (tried in order: Groq → OpenRouter → Ollama) ──

# 1. Groq (free: https://console.groq.com/keys)
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# 2. OpenRouter (free: https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 3. Ollama (local fallback, no key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embeddings (local, free, no API key needed) ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage ──
CHROMA_PERSIST_DIR=./chroma_db
KNOWLEDGE_DIR=../knowledge

# ── CORS ──
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
